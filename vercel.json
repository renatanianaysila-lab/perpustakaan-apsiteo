{
    "version": 2,
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_KEY": "base64:Fbi60UI2MsFG+rH+xytDkFUBOAHVmozUR1pkp7weOBw=",
        "DB_CONNECTION": "pgsql",
        "DATABASE_URL": "postgres://postgres:[YOUR-PASSWORD]@db.twcuxpqxvftzmzyzfxwp.supabase.com:5432/postgres?sslmode=require"
    },
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.3"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|images)/(.*)",
